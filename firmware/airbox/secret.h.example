#pragma once
// AirBox OTA credentials — TEMPLATE.
//
// Copy this file to `secret.h` (same directory) and set your own password, then
// recompile and flash. `secret.h` is gitignored so your credentials never land
// in the repo.
//
// When secret.h is present, network OTA (/update and the /ota/* upload
// endpoints) is protected by HTTP Basic Auth. This defeats the realistic threat
// to a LAN device — an IoT worm scanning for open ESP OTA endpoints. It is plain
// HTTP, so it does NOT protect against an on-path LAN attacker; for that you'd
// need signed images / Secure Boot, which is overkill for a trusted-LAN gift.
//
// If secret.h is ABSENT, the build still compiles but OTA is unauthenticated and
// emits a #warning. For a build with NO network flash path at all (USB-only,
// maximum hardening), set ENABLE_NET_OTA 0 in config.h instead.
//
// Generate a strong password, e.g.:
//   LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c 28; echo
#define OTA_USERNAME "airbox"
#define OTA_PASSWORD "change-me-to-a-long-random-string"
